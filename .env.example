# ============================================
# Fivetran
# ============================================
# REST API credentials - https://fivetran.com/account/settings
FIVETRAN_API_KEY=<your-api-key>
FIVETRAN_API_SECRET=<your-api-secret>

# ID of the fivetran_connector.orders_s3 resource (infra/fivetran.tf),
# or the Terraform output fivetran_connector_id once applied.
FIVETRAN_CONNECTOR_ID=<your-connector-id>

# MDLS destination group id - obtained by running
# scripts/create_mdls_destination.sh once per environment. Pasted into
# infra/terraform.tfvars as fivetran_mdls_destination_id, never committed.
FIVETRAN_MDLS_DESTINATION_ID=<your-mdls-destination-group-id>

# External ID Fivetran supplies for the IAM role trust policies in
# infra/iam_mdls.tf and infra/source_landing.tf.
FIVETRAN_S3_EXTERNAL_ID=<your-external-id>

# ============================================
# AWS (only needed for generate_and_sync.yml's live S3 upload, or for
# running Terraform / the bootstrap script locally)
# ============================================
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
AWS_REGION=us-west-2
SOURCE_BUCKET_NAME=jason-chletsos-cicd-odi-demo-landing
MDLS_BUCKET_NAME=jason-chletsos-cicd-odi-demo-mdls

# Role ARN Fivetran assumes to write the MDLS bucket - the
# aws_iam_role.fivetran_mdls_access output from `terraform apply`. Required
# by scripts/create_mdls_destination.sh.
MDLS_ROLE_ARN=<arn:aws:iam::account-id:role/fivetran-mdls-access>
MDLS_EXTERNAL_ID=<same value as FIVETRAN_S3_EXTERNAL_ID above>

# ============================================
# Snowflake (OPTIONAL - only used when enable_snowflake_consumer = true in
# infra/terraform.tfvars, and by the "snowflake" dbt target in
# transform/profiles.yml). Never used in CI.
# ============================================
SNOWFLAKE_ACCOUNT=<your-account-locator>
SNOWFLAKE_USER=<your-user>
SNOWFLAKE_PASSWORD=<your-password>
SNOWFLAKE_ROLE=<your-role>
SNOWFLAKE_DATABASE=<your-database>
SNOWFLAKE_WAREHOUSE=<your-warehouse>
SNOWFLAKE_SCHEMA=<your-schema>
